# Sector Graph 服务端环境变量配置示例 (用于生产挂载)
#
# ----------------------------------------------------
# 用法：复制此文件为 `server/.env`，后端将自动隔离加载配置
# `pip install python-dotenv` 启用本文件解析
# ----------------------------------------------------

# 服务启动配置
HOST=0.0.0.0
PORT=8000
DEBUG=False

# 数据库存储
# 默认情况下使用项目根目录外的 data/sector_graph.db
# 在生产服务器下，可指向特定的高可用存储盘
# DB_PATH=/var/lib/sectordb/sector_graph.db

# （可选）安全跨域通信策略
# CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# 初始的大语言模型 API (用于无头启动时注册第一个有效账密)
# 日常使用建议直接在前端的 【⚙️ 设置看板】 内维护
# AI_DEFAULT_PROVIDER=minimax
# AI_MINIMAX_KEY=your_minimax_secret_key
# AI_MINIMAX_URL=https://api.minimax.chat/v1
# AI_DEEPSEEK_KEY=your_deepseek_secret_key
